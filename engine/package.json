{
  "name": "@18ai/engine",
  "version": "0.0.0",
  "private": true,
  "description": "18Chesapeake game engine — pure TypeScript, framework-free. See ../docs/architecture.md.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
